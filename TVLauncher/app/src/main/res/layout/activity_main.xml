<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0000FF"
    android:orientation="vertical"
    android:paddingStart="90dp"
    android:paddingEnd="90dp"
    android:paddingTop="30dp"
    android:paddingBottom="30dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="5dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/ic_usb"
            android:layout_width="54dp"
            android:layout_height="47dp"
            android:layout_marginEnd="1dp"
            android:background="@drawable/selector_focus_top_icon"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_usb"
            android:contentDescription="@null"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/ic_wifi"
            android:layout_width="47dp"
            android:layout_height="60dp"
            android:layout_marginEnd="1dp"
            android:background="@drawable/selector_focus_top_icon"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_wifi_on"
            android:contentDescription="@null"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_size_status_time"
            tools:text="8:08 AM" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_size_status_date"
            tools:text="Saturday, November 11" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="5dp"
        android:layout_marginTop="30dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:baselineAligned="false">

        <include
            android:id="@+id/card_netflix"
            layout="@layout/item_card_netflix"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_cards" />

        <include
            android:id="@+id/card_youtube"
            layout="@layout/item_card_youtube"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_cards" />

        <include
            android:id="@+id/card_play"
            layout="@layout/item_card_play"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_cards" />

        <include
            android:id="@+id/card_chrome"
            layout="@layout/item_card_chrome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="5dp"
        android:layout_marginTop="20dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:baselineAligned="false">

        <include
            android:id="@+id/btn_keystone"
            layout="@layout/item_btn_keystone"
            android:layout_width="0dp"
            android:layout_height="@dimen/function_btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_btns" />

        <include
            android:id="@+id/btn_miracast"
            layout="@layout/item_btn_miracast"
            android:layout_width="0dp"
            android:layout_height="@dimen/function_btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_btns" />

        <include
            android:id="@+id/btn_signal_source"
            layout="@layout/item_btn_signal_source"
            android:layout_width="0dp"
            android:layout_height="@dimen/function_btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_btns" />

        <include
            android:id="@+id/btn_my_apps"
            layout="@layout/item_btn_my_apps"
            android:layout_width="0dp"
            android:layout_height="@dimen/function_btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_between_btns" />

        <include
            android:id="@+id/btn_settings"
            layout="@layout/item_btn_settings"
            android:layout_width="0dp"
            android:layout_height="@dimen/function_btn_height"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>